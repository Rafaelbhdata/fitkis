# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Anthropic (Coach AI)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Portal clínico
# NEXT_PUBLIC_SITE_URL: visible en cliente — usar localhost en dev.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# SERVER_URL: server-only — URL pública del sitio para links en emails (redirectTo, magic links).
# En desarrollo: http://localhost:3000  |  En producción: https://fitkis.com
# IMPORTANTE: configurar en Vercel → Settings → Environment Variables → Production only.
SERVER_URL=http://localhost:3000

# Resend (emails transaccionales — reagendamiento de citas)
# Obtén tu API key en https://resend.com — sin esto el email no se envía pero el flujo sigue funcionando
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Google Calendar (integración opcional — bloquea slots del calendario personal)
# Crear en Google Cloud Console > APIs & Services > Credentials > OAuth 2.0 Client ID
# Habilitar: Google Calendar API | Scope: calendar.freebusy
GOOGLE_CALENDAR_CLIENT_ID=your_google_client_id
GOOGLE_CALENDAR_CLIENT_SECRET=your_google_client_secret
# En desarrollo: http://localhost:3000/api/auth/google-calendar/callback
# En producción:  https://www.fitkis.com/api/auth/google-calendar/callback
GOOGLE_CALENDAR_REDIRECT_URI=https://www.fitkis.com/api/auth/google-calendar/callback

