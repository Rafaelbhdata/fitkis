# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Anthropic (Coach AI)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Portal clínico
# URL base del sitio — usada para el redirectTo del invite email y links de reagendamiento.
# En desarrollo: http://localhost:3000  |  En producción: https://tudominio.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend (emails transaccionales — reagendamiento de citas)
# Obtén tu API key en https://resend.com — sin esto el email no se envía pero el flujo sigue funcionando
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
