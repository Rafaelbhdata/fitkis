# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Anthropic (Coach AI)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Portal clínico
# URL base del sitio — usada para el redirectTo del invite email.
# En desarrollo: http://localhost:3000  |  En producción: https://tudominio.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Email del administrador. Solo esta cuenta puede acceder a /admin/invite
# y llamar a /api/invite-professional.
ADMIN_EMAIL=tu@email.com
# Expuesto al cliente para ocultar el panel de admin en el browser.
NEXT_PUBLIC_ADMIN_EMAIL=tu@email.com
